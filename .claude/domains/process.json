{
  "domain": "process",
  "description": "Euronext red-team process, methodology, diagram, and regulatory alignment analysis.",
  "selector": {
    "script": ".claude/skills/document-ingest/select_inputs.py",
    "args": ["inputs", "--domain", "process"],
    "policy": {
      "prefer_docx_over_pdf": true,
      "keep_latest_version_only": true,
      "drop_drawio_renders_when_source_exists": true
    }
  },
  "ingest": {
    "skill": "document-ingest",
    "script": ".claude/skills/document-ingest/ingest_one.py",
    "args": ["--domain", "process"]
  },
  "evaluators": [
    "engagement-lifecycle-review",
    "tiber-dora-alignment"
  ],
  "corpus_evaluators": [
    "corpus-coherence"
  ],
  "synthesizer": "findings-synthesizer",
  "primary_output_schema": "schemas/finding.schema.json"
}
