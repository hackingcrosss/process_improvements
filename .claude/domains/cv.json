{
  "domain": "cv",
  "description": "CV/resume, cover-letter, portfolio, and job-description analysis.",
  "selector": {
    "script": ".claude/skills/document-ingest/select_inputs.py",
    "args": ["inputs", "--domain", "cv"],
    "policy": {
      "prefer_docx_over_pdf": false,
      "keep_latest_version_only": false,
      "drop_drawio_renders_when_source_exists": true,
      "group_candidate_bundles": true
    }
  },
  "ingest": {
    "skill": "document-ingest",
    "script": ".claude/skills/document-ingest/ingest_one.py",
    "args": ["--domain", "cv"]
  },
  "evaluators": [
    "cv-profile-extractor",
    "cv-consistency-review",
    "cv-privacy-review",
    "cv-job-match-review"
  ],
  "corpus_evaluators": [],
  "synthesizer": "cv-synthesizer",
  "primary_output_schemas": [
    "schemas/cv/cv-profile.schema.json",
    "schemas/cv/cv-evaluation.schema.json",
    "schemas/finding.schema.json"
  ]
}
